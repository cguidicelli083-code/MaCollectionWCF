<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Accès réseau (argus eBay + estimation IA de secours). -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Prise de photo (scan). La sélection depuis la galerie passe par le sélecteur de photos
         moderne d'Android (PickVisualMedia), qui ne nécessite aucune permission de lecture média. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:name=".MaCollectionWcfApp"
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.MaCollectionWcf">

        <!-- Pré-télécharge les modèles ML Kit (code-barres + OCR, dont le japonais) à l'installation. -->
        <meta-data
            android:name="com.google.mlkit.vision.DEPENDENCIES"
            android:value="barcode,ocr,ocr_japanese" />

        <!-- ⚠️ ID de TEST Google officiel (ca-app-pub-3940256099942544~3347511713) — à remplacer
             par le vrai App ID AdMob du compte de l'utilisateur avant toute mise en ligne réelle
             sur le Play Store (voir aussi les ID d'unité pub bannière/interstitiel dans AdsManager.kt). -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3940256099942544~3347511713" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Notre thème par défaut n'a pas de barre d'outils (NoActionBar) : sans cette
             redéfinition, l'écran de recadrage de la bibliothèque hérite de ce thème et le
             bouton de validation (dans la barre d'outils) ne s'affiche jamais. -->
        <activity
            android:name="com.canhub.cropper.CropImageActivity"
            android:theme="@style/Theme.AppCompat" />

        <!-- Verrouillé en portrait : une rotation recréerait l'écran et perdrait tout
             formulaire en cours (les champs ne sont pas conçus pour survivre à ça). -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
