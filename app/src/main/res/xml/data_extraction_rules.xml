<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+). Même politique que backup_rules.xml : base Room + préférences uniquement,
  photos exclues (couvertes par le .zip manuel).
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
